# Default environment configuration. Override per-environment as needed.
APP_ENV=dev
APP_SECRET=please_change_this_in_prod

# Bearer token that grants the unrestricted "root" role.
ROOT_API_TOKEN=root-secret-token

# DSN for MySQL (matches the docker-compose service "db").
DATABASE_URL="mysql://app:app@db:3306/user_api?serverVersion=8.0&charset=utf8mb4"
